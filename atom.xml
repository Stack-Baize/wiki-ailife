    <title>DISC 行为风格理论</title>
    <link href="https://wiki.ailife.cc/%E7%94%9F%E6%B4%BB%E5%AD%A6%E4%B9%A0/DISC-%E8%A1%8C%E4%B8%BA%E9%A3%8E%E6%A0%BC%E7%90%86%E8%AE%BA.html"/>
    <id>https://wiki.ailife.cc/%E7%94%9F%E6%B4%BB%E5%AD%A6%E4%B9%A0/DISC-%E8%A1%8C%E4%B8%BA%E9%A3%8E%E6%A0%BC%E7%90%86%E8%AE%BA.html</id>
